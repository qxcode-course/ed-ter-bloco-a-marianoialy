            "content": "package main\n\nimport \"fmt\"\n\nfunc main() {\n\tvar quantfig int\n\tvar quantpossui int\n\tfmt.Scan(&quantfig)\n\tfmt.Scan(&quantpossui)\n\tvetor := make([]int, quantpossui)\n\trepetidas := make([]int, quantpossui)\n\tvar quantrep int\n\tfor i := 0; i < quantpossui; i++ {\n\t\tfmt.Scan(&vetor[i])\n\t}\n\tfor i := 0; i < quantpossui; i++ {\n\t\tif vetor[i] == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tfor j := i + 1; j < quantpossui; j++ {\n\t\t\tif vetor[i] == vetor[j] {\n\t\t\t\trepetidas[quantrep] = vetor[j]\n\t\t\t\tquantrep++\n\t\t\t\tvetor[j] = 0\n\t\t\t}\n\t\t}\n\t}\n\tif quantrep == 0 {\n\t\tfmt.Println(\"N\")\n\t} else {\n\t\tfor i := 0; i < quantrep; i++ {\n\t\t\tif i > 0 {\n\t\t\t\tfmt.Print(\" \")\n\t\t\t}\n\t\t\tfmt.Print(repetidas[i])\n\t\t}\n\t\tfmt.Println()\n\t}\n\n\tfaltantes := make([]int, quantfig)\n\tquantfalt := 0\n\tfor i := 1; i <= quantfig; i++ {\n\t\tcount := 0\n\t\tfor j := 0; j < quantpossui; j++ {\n\t\t\tif vetor[j] == i {\n\t\t\t\tcount++\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif count == 0 {\n\t\t\tfaltantes[quantfalt] = i\n\t\t\tquantfalt++\n\t\t}\n\t}\n\tif quantfalt == 0 {\n\t\tfmt.Println(\"N\")\n\t} else {\n\t\tfor i := 0; i < quantfalt; i++ {\n\t\t\tif i > 0 {\n\t\t\t\tfmt.Print(\" \")\n\t\t\t}\n\t\t\tfmt.Print(faltantes[i])\n\t\t}\n\t\tfmt.Println()\n\t}\n}\n",
